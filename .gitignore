# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data, such as
# password, private keys, and user names.
*.tfvars
*.tfvars.json

# Ignore override files as they may contain local overrides
*override.tf
*override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# macOS system files
.DS_Store
**/.DS_Store
**/._*

# Temporary files
*.tmp
*~
